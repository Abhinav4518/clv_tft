import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import plotly.express as px




# Set aesthetic styling for plots
sns.set_theme(style="darkgrid")

# Load the synthetic data we generated
df = pd.read_csv('../data/raw_customer_data.csv')
df['date'] = pd.to_datetime(df['date'])

print(f"Dataset Shape: {df.shape}")
display(df.head())





plt.figure(figsize=(10, 5))
sns.histplot(df[df['daily_spend'] > 0]['daily_spend'], bins=50, kde=True, color='purple')
plt.title('Distribution of Daily Spend (Excluding $0 Days)')
plt.xlabel('Spend ($)')
plt.ylabel('Frequency')
plt.show()

zero_spend_pct = (len(df[df['daily_spend'] == 0]) / len(df)) * 100
print(f"Percentage of days with $0 spend: {zero_spend_pct:.2f}%")


# Grab the first Gold tier customer
sample_customer = df[df['customer_tier'] == 'Gold']['customer_id'].iloc[0]
cust_df = df[df['customer_id'] == sample_customer].copy()

# Create a Plotly interactive chart
fig = px.line(cust_df, x='date', y='daily_spend', title=f'Daily Spend Timeline for {sample_customer}')

# Highlight the holidays in red
holidays = cust_df[cust_df['is_holiday'] == 1]
fig.add_scatter(x=holidays['date'], y=holidays['daily_spend'], 
                mode='markers', marker=dict(color='red', size=10), 
                name='Holiday Spike')

fig.show()



